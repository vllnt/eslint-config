{
  "name": "@vllnt/eslint-config",
  "version": "1.0.0",
  "type": "module",
  "description": "Strict ESLint config for TypeScript projects. All rules enforce error — no warnings.",
  "license": "MIT",
  "main": "./flat/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/vllnt/eslint-config"
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "typescript",
    "react",
    "nextjs",
    "prettier"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2",
  "files": [
    "flat"
  ],
  "exports": {
    ".": "./flat/index.js",
    "./nextjs": "./flat/nextjs.js",
    "./nodejs": "./flat/nodejs.js",
    "./convex": "./flat/convex.js",
    "./react": "./flat/react.js",
    "./turbo": "./flat/turbo.js",
    "./boundaries": "./flat/boundaries.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test tests/smoke.test.js",
    "prepublishOnly": "node --test tests/smoke.test.js"
  },
  "dependencies": {
    "@convex-dev/eslint-plugin": "^1.2.1",
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^5.4.0",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-functional": "^9.0.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-turbo": "^2.8.10",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-write-good-comments": "^0.2.0",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "prettier": ">=3",
    "typescript": ">=5"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "handlebars": ">=4.7.9"
    }
  }
}
